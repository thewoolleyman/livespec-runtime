// Project-local livespec configuration for livespec-runtime.
//
// This sibling library dogfoods livespec at the LIBRARY scale, second
// such (livespec-dev-tooling was first). The SPECIFICATION/ tree at the
// repo root is the live spec for this library; this library's own impl
// tracking lives in a per-repo beads/Dolt TENANT database on the shared
// dolt-server (tenant name "livespec-runtime"), via livespec-orchestrator-beads-fabro.
// (The pre-cutover plaintext work-items.jsonl / memos.jsonl snapshot is
// frozen read-only under archive/ — see archive/README.md.)
//
// Authority: livespec/SPECIFICATION/contracts.md
//   §"Cross-repo coordination — pin-and-bump" (sibling libraries take
//   the same pin-and-bump shape as impl-plugins)
//   §"Cross-repo dependency awareness" (the H2 landed by li-e7h6ki +
//   parent epic li-6d2wpj that names livespec-runtime as the shared
//   runtime library)
//
// Status: SPECIFICATION/ is seeded via /livespec:seed as a follow-up
// after the v0.1.0 tag lands (per li-ufvfmb's "seed its own
// SPECIFICATION/ via the livespec template"). The initial scaffold ships
// the .livespec.jsonc and the package skeleton; the cross_repo impl
// lands via li-aclzfe against the seeded spec.
{
  "template": "livespec",
  "spec_root": "SPECIFICATION",
  "implementation": { "plugin": "livespec-orchestrator-beads-fabro" },
  // Credential-injection wrapper (fleet default) prefixed to the beads CLIs so a bare invocation self-heals its tenant secret.
  "credential_wrapper": ["/usr/local/bin/with-livespec-env.sh", "--"],
  "harnesses": {
    "claude": { "status": "exempt", "reason": "livespec-runtime is a library; it ships no command/skill surface to resolve from a harness" },
    "codex":  { "status": "exempt", "reason": "livespec-runtime is a library; it ships no command/skill surface to resolve from a harness" }
  },
  "livespec-runtime": {
    "compat": {
      // semver range and pinned tag against livespec-core. The pinned
      // value is "master" until livespec-core's first post-v072 release
      // tag (revising the propose-change from li-e7h6ki); doctor's
      // contract-version-compatibility invariant currently fires `warn`
      // against "master" pins, which is expected during bootstrap.
      "livespec": ">=0.1.0,<1.0.0",
      "pinned": "v0.19.0"
    }
  },
  "livespec-orchestrator-beads-fabro": {
    // Substrate marker. The plaintext sibling declared "jsonl"; this
    // plugin's substrate is a per-repo beads/Dolt TENANT database on the
    // shared dolt-server (NOT JSONL files at the repo root). The frozen
    // pre-cutover JSONL snapshot lives under archive/ (see archive/README.md).
    "format": "beads",
    "compat": {
      "livespec": ">=0.1.0,<1.0.0",
      "pinned": "v0.19.0"
    },
    // Per-repo beads tenant CONNECTION block, read by the plugin's
    // commands/_config.py and overlaid by LIVESPEC_BD_PATH /
    // LIVESPEC_BEADS_FAKE. `prefix` == `tenant` == `database` ==
    // `server_user` is the load-bearing tenant identity rule (all four are
    // this repo's name, "livespec-runtime"). TCP-only: NO `socket` key —
    // the dolt unix socket dir is 0750 dolt:dolt and inaccessible to this
    // caller, so the connection must go over 127.0.0.1:3307.
    //
    // The tenant PASSWORD is deliberately ABSENT — it is supplied only via
    // the BEADS_DOLT_PASSWORD environment variable at bd-call time and is
    // NEVER committed here.
    //
    // `fake` is false so the committed config describes the REAL
    // connection; CI and tests set LIVESPEC_BEADS_FAKE=1 to force the
    // hermetic in-memory backend (GitHub CI cannot reach the localhost
    // dolt-server).
    "connection": {
      "tenant": "livespec-runtime",
      "prefix": "livespec-runtime",
      "database": "livespec-runtime",
      "server_user": "livespec-runtime",
      "server_host": "127.0.0.1",
      "server_port": 3307,
      "fake": false
    },
    // Autonomous-mode levers (maintainer-directed 2026-07-20). Two of the three
    // policy settings in livespec/SPECIFICATION/contracts.md §"The three policy
    // settings" are moved off their safe defaults so ready work is ADMITTED and
    // ACCEPTED without a human valve:
    //   auto_approve_ready: true      — pending-approval → ready with no human.
    //   acceptance_mode: "ai-only"    — post-merge acceptance without a human.
    // The third lever, `merge_on_review_cap`, deliberately STAYS at its safe
    // `false` default and is NOT listed here: a review that cannot converge
    // within `review_fix_cap` rounds is precisely the case that must reach a
    // human, per the design record cited in that section. A design-human-gated
    // (spec-change-tier) item still cannot auto-approve regardless of these.
    //
    // EDIT THIS BLOCK BY HAND. Do NOT use `drive --action set-config:<k>:<v>`:
    // that surface round-trips the file through json.dumps and silently strips
    // every comment here while reporting green — tracked as bd-ib-lmi5.
    "dispatcher": {
      "auto_approve_ready": true,
      "acceptance_mode": "ai-only"
    }
  }
}
